# Copia este archivo a ".env" y rellena los valores reales.
# El archivo .env NUNCA se sube al repositorio (está en .gitignore).

# Clave secreta de Flask (genera una con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=pon-aqui-una-clave-larga-y-aleatoria

# Cadena de conexión a la base de datos.
# Local (SQLite, por defecto):
DATABASE_URL=sqlite:///notes.db
# En la nube (PostgreSQL de Render), ejemplo:
# DATABASE_URL=postgresql://usuario:password@host:5432/nombre_bd
